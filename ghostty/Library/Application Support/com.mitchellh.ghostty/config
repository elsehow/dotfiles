# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

# Move between splits with Ctrl+h/j/k/l (vim-style)
keybind = performable:cmd+h=goto_split:left
keybind = performable:cmd+j=goto_split:bottom
keybind = performable:cmd+k=goto_split:top
keybind = performable:cmd+l=goto_split:right

font-family = "Inconsolata"
font-size = 23

# Always use a block cursor (apps can still override via DECSCUSR)
cursor-style = block
# Stop Ghostty's shell integration from forcing a bar cursor at the prompt
shell-integration-features = no-cursor,no-sudo,title,no-ssh-env,no-ssh-terminfo,path

background-opacity = 1.0
background-blur-radius = 100
macos-titlebar-style = "hidden"
# window-padding-x is 20 (a touch tighter). Note: the sketchybar left text inset is
# 26 (bar padding 14 + item padding 4 + icon padding 8), so terminal text in a
# left-column window now sits ~6px left of the bar's leftmost label rather than flush
# under it. balance stays OFF regardless — on, it adds variable leftover padding on
# the left and shoves the extra space to the right edge.
window-padding-balance = false
window-padding-x = 20
window-padding-y = 10
mouse-hide-while-typing = true
window-decoration = true

theme = GitHub Light Default
