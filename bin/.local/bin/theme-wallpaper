#!/usr/bin/env bash
#
# theme-wallpaper — set the macOS desktop from the current Ghostty theme.
#
# Two modes:
#   • SOLID (default) — a single color: the theme background DARKENED, so the
#     tiling gaps read as a recessed gutter and windows appear to float. Light
#     themes darken to a warm "paper" gray; dark themes to a deep gutter. Pure
#     stdlib, works on any machine.
#   • TEXTURE (--texture) — a subtle procedural wallpaper rendered from the
#     theme's full palette via theme-texture, in one of several STYLES
#     (mesh | flat | flow | tiedye | ribbon —
#      the last two loud/psychedelic, the rest calm).
#     Needs numpy + Pillow; falls back to SOLID if they're missing.
#
# Both stay in-hue with the terminal and pair well with 0% window transparency.
#
# Usage:
#   theme-wallpaper                  solid color derived from the live theme
#   theme-wallpaper --solid          same (explicit)
#   theme-wallpaper "#1e1e2e"        solid, explicit color (exact bg = seamless)
#   theme-wallpaper --texture        procedural wallpaper (style = mesh, default)
#   theme-wallpaper --texture flat   procedural wallpaper in a specific style
#
# set-theme repaints with --texture by default; set THEME_WALLPAPER_MODE=--solid
# to make it use a solid color instead.
#
# Env:
#   THEME_WALLPAPER_SIZE   output WxH (default 3840x2160 — 4K; ample behind tiled
#                          windows. Bump to 7680x3240 for 8K if you ever need it.)
#   THEME_WALLPAPER_STYLE  texture style: mesh | flat | flow | tiedye | ribbon
#                          (default mesh)
#   THEME_WALLPAPER_HARMONY mono (default) | complement | split | triad |
#                          analogous — rotate the wallpaper around the color wheel
#                          relative to the theme hue, so the desktop complements
#                          the terminal instead of just matching it. Works in both
#                          solid and texture mode.
#   THEME_WALLPAPER_CACHE_CAP cache size budget in BYTES (default 400 MiB). After
#                          each render the cache is pruned oldest-first until under
#                          this, so renders don't accumulate unbounded. Set to 0 to
#                          disable pruning.
#
set -euo pipefail

GB=/Applications/Ghostty.app/Contents/MacOS/ghostty
SIZE="${THEME_WALLPAPER_SIZE:-3840x2160}"
CACHE="$HOME/.cache/theme-wallpaper"
# Cache is keyed by content (theme|bg|accents|style|harmony|version|size) and
# never overwrites, so it grows with every new combination AND orphans every
# render from a past schema version. 8K textures run 5–27 MB each, so this leaks
# fast. Bound it: prune oldest-first after each render. Default 400 MiB.
CACHE_CAP="${THEME_WALLPAPER_CACHE_CAP:-419430400}"

# Capture the resolved config once (one ghostty call, no SIGPIPE under pipefail).
cfg="$("$GB" +show-config 2>/dev/null || true)"
get() { printf '%s\n' "$cfg" | grep -m1 "^$1 = " | sed "s/^$1 = //" || true; }

# Darken a #rrggbb toward black (preserves hue, so warm whites stay warm).
darken() {
  python3 - "$1" <<'PY'
import sys
def rgb(h):
    h = h.lstrip('#')
    if len(h) == 3: h = ''.join(c*2 for c in h)
    return tuple(int(h[i:i+2], 16) for i in (0, 2, 4))
print('#%02x%02x%02x' % tuple(round(x*0.65) for x in rgb(sys.argv[1])))
PY
}

# Rotate a #rrggbb around the color wheel by the harmony scheme's base offset,
# lifting saturation so the rotated hue reads (a near-grey bg rotated 180° is
# still near-grey otherwise). Keeps value, so dark stays dark. Mirrors
# theme-texture's harmonize_base so solid mode matches the texture path. Unknown
# modes are a no-op (offset 0, original sat) → safe pass-through.
harmonize() { # hex mode
  python3 - "$1" "$2" <<'PY'
import sys, colorsys
hexv, mode = sys.argv[1].lstrip('#'), sys.argv[2]
off = {'complement': 180, 'split': 180, 'triad': 120, 'analogous': 30}.get(mode)
r, g, b = (int(hexv[i:i+2], 16) / 255.0 for i in (0, 2, 4))
H, S, V = colorsys.rgb_to_hsv(r, g, b)
if off is not None:
    H = (H + off / 360.0) % 1.0
    S = max(S, 0.30)
r, g, b = colorsys.hsv_to_rgb(H, S, V)
print('#%02x%02x%02x' % (round(r*255), round(g*255), round(b*255)))
PY
}

set_wallpaper() { # path
  osascript -e "tell application \"System Events\" to set picture of every desktop to \"$1\"" >/dev/null 2>&1 || true
}

# Bound the cache: if total bytes exceed CACHE_CAP, delete files oldest-first
# (by mtime) until under it. Never deletes $1 (the render we just set as the live
# wallpaper), regardless of its age. CACHE_CAP=0 disables. Pure python3 stdlib.
prune_cache() { # keep_path
  [ "${CACHE_CAP:-0}" -gt 0 ] || return 0
  python3 - "$CACHE" "$CACHE_CAP" "${1:-}" <<'PY'
import os, sys
cache, cap, keep = sys.argv[1], int(sys.argv[2]), sys.argv[3]
keep = os.path.realpath(keep) if keep else ""
try:
    files = [(s.st_mtime, s.st_size, p)
             for n in os.listdir(cache)
             for p in [os.path.join(cache, n)]
             if os.path.isfile(p) for s in [os.stat(p)]]
except FileNotFoundError:
    sys.exit(0)
total = sum(sz for _, sz, _ in files)
if total <= cap:
    sys.exit(0)
running = 0
for _, sz, p in sorted(files, reverse=True):   # newest first; keep newest
    if os.path.realpath(p) == keep:            # always retain the live wallpaper
        running += sz
        continue
    running += sz
    if running > cap:
        try: os.remove(p)
        except OSError: pass
PY
}

solid_png() { # hex path  — pure-stdlib solid PNG (no numpy/PIL needed)
  python3 - "$1" "$2" <<'PY'
import sys, zlib, struct
hexv, path = sys.argv[1], sys.argv[2]
r, g, b = (int(hexv[i:i+2], 16) for i in (0, 2, 4))
w = h = 64
raw = (b'\x00' + bytes((r, g, b)) * w) * h           # filter byte 0 + RGB pixels
def chunk(t, d):
    c = t + d
    return struct.pack('>I', len(d)) + c + struct.pack('>I', zlib.crc32(c) & 0xffffffff)
png  = b'\x89PNG\r\n\x1a\n'
png += chunk(b'IHDR', struct.pack('>IIBBBBB', w, h, 8, 2, 0, 0, 0))   # 8-bit RGB
png += chunk(b'IDAT', zlib.compress(raw, 9))
png += chunk(b'IEND', b'')
open(path, 'wb').write(png)
PY
}

set_solid() {
  local bg color hex out
  bg="$(get background)"; bg="${bg:-#1e1e2e}"
  # Harmony rotates the derived color off the theme hue; an explicit color arg is
  # taken verbatim (the caller asked for exactly that).
  [ "$HARMONY" != mono ] && bg="$(harmonize "$bg" "$HARMONY")"
  if [ -n "${1:-}" ]; then color="$1"; else color="$(darken "$bg")"; fi
  hex="${color#\#}"
  out="$CACHE/${hex}.png"
  mkdir -p "$CACHE"
  solid_png "$hex" "$out"
  set_wallpaper "$out"
  prune_cache "$out"
  echo "✔ wallpaper → #${hex}   (theme bg ${bg})"
}

set_texture() {
  local bg name accents seed key out harm hsuf
  bg="$(get background)"; bg="${bg:-#1e1e2e}"
  name="$(get theme)"; name="${name:-default}"
  # Accents = the colorful end of the 16-color ANSI palette (red/green/blue/
  # magenta); fall back to the foreground if a theme defines no palette.
  accents="$(printf '%s\n' "$cfg" | grep -E '^palette = (1|2|4|5)=' | sed -E 's/.*=//' | paste -sd, -)"
  [ -z "$accents" ] && accents="$(get foreground)"
  seed="$(printf '%s' "$name" | cksum | cut -d' ' -f1)"
  # Opt-in color harmony: rotate the field around the wheel off the theme hue.
  harm=""; [ "$HARMONY" != mono ] && harm="--harmony $HARMONY"
  # theme-texture takes the RAW bg (it does its own luminance-aware darken), so
  # the cache key tracks the raw bg + style + harmony + a schema version bump.
  key="$(printf '%s' "${name}|${bg}|${accents}|${STYLE}|${HARMONY}|v9|${SIZE}" | cksum | cut -d' ' -f1)"
  out="$CACHE/tex-${STYLE}-${key}.png"
  mkdir -p "$CACHE"
  # Cache by content key: re-switching to a theme/style reuses its render instantly.
  if [ ! -f "$out" ]; then
    if ! theme-texture --out "$out" --size "$SIZE" --base "$bg" --accents "$accents" --seed "$seed" --style "$STYLE" $harm; then
      echo "↩ texture unavailable — falling back to solid" >&2
      set_solid; return
    fi
  fi
  set_wallpaper "$out"
  prune_cache "$out"
  hsuf=""; [ "$HARMONY" != mono ] && hsuf=",$HARMONY"
  echo "✔ texture(${STYLE}${hsuf}) → bg ${bg}, accents ${accents}   (theme ${name})"
}

# Texture style: explicit 2nd arg (theme-wallpaper --texture flat) wins, else env.
STYLE="${THEME_WALLPAPER_STYLE:-mesh}"
# Color harmony: rotate the field around the wheel relative to the theme hue.
HARMONY="${THEME_WALLPAPER_HARMONY:-mono}"

case "${1:-}" in
  -h|--help) sed -n '2,42p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
  --texture) [ -n "${2:-}" ] && STYLE="$2"; set_texture ;;
  --solid)   set_solid ;;
  *)         set_solid "${1:-}" ;;
esac
