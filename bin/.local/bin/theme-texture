#!/usr/bin/env python3
"""theme-texture — render a subtle procedural wallpaper from a theme palette.

This is the "art file". It offers a few interchangeable *styles*, each taking the
same inputs (a theme background + a handful of accent colors + a seed) and
returning a PIL Image meant to sit calmly BEHIND tiled windows — low contrast,
value near the base, quiet in the center where windows live.

Styles (--style):
  mesh     (default) soft inverse-distance gradient. Bright/dark/accent pools are
           pushed to the RIM and a center vignette keeps the middle calm; colors
           mix in linear-light (no muddy brown between complementary accents);
           accents (up to 3) are desaturated toward the base. Reads as a matte
           wall with visible tint and light/dark drift toward the edges.
  flat     the calmest: a single soft corner-to-corner directional gradient with a
           whisper of accent glow in one corner. Closest to a plain matte wall.
  flow     thousands of particles streamed along a noise vector field into glowing
           streamlines, hued by their start position so the palette flows in
           coherent multicolor bands across the canvas. Sinuous and organic.
  tiedye   psychedelic full-spectrum spiral folded around a jittered center and
           warped into organic bleed. Loud, not calm — the one to reach for when
           you want a rice that screams. accents ignored (tie-dye is the rainbow).
  ribbon   2000s flowy 3D lines: translucent silk ribbons sine-waving across the
           canvas with rounded speculars, hued across the spectrum so the overlaps
           read like a Vista/Windows-Media-Player aurora.

The last two are the loud styles — every other style stays near the base value so
it sits calmly behind windows; tiedye/ribbon are hue-driven and vivid by design
(both still calm the center so windows stay legible).

Base treatment is luminance-aware and lives HERE (not in the caller): pass the
RAW theme background as --base. Dark themes darken hard into a recessed gutter;
light themes barely darken, so "paper" backgrounds stay warm and papery.

Accent choice is shuffled per-seed (pick_accents), so styles don't always grab
the same palette slot (e.g. flow isn't perpetually red) — but stays stable
for a given theme, since the caller seeds from the theme name.

Swap or add a style by writing a new render_<name>(w, h, base, accents, seed,
opts) → PIL Image and registering it in STYLES. Prototype shaders in
glslViewer / Shadertoy, then port the math here so the pipeline stays headless.

Usage:
  theme-texture --out PATH --size WxH --base "#rrggbb" \
                --accents "#r1,#g2,#b4" [--seed N] \
                [--style mesh|flat|flow|tiedye|ribbon] \
                [--harmony mono|complement|split|triad|analogous] \
                [--blend 0.20] [--dither 2.0] [--grain 3.0] [--power 1.6]

--harmony rotates the wallpaper AROUND the color wheel relative to the theme
background hue, so the desktop *relates* to the terminal by a color scheme
instead of just matching it. mono (default) keeps the in-hue look; complement
rotates the field 180° (blue terminal → amber desktop); split/triad/analogous
are the milder schemes. Unlike the calm in-hue path, harmony lifts the base
saturation so the rotated hue actually reads, and replaces the theme's own
accents with ones generated at the scheme's angles (anchored on the theme hue,
so offset 0 — the terminal's own hue — stays in the mix as a tie-back).
"""
import argparse
import colorsys
import math
import sys

try:
    import numpy as np
    from PIL import Image
except ImportError:
    sys.stderr.write(
        "theme-texture needs numpy + Pillow:  pip3 install numpy pillow\n"
    )
    sys.exit(2)

# Standard 8x8 Bayer matrix (values 0..63) for ordered dithering.
BAYER8 = np.array([
    [ 0, 32,  8, 40,  2, 34, 10, 42],
    [48, 16, 56, 24, 50, 18, 58, 26],
    [12, 44,  4, 36, 14, 46,  6, 38],
    [60, 28, 52, 20, 62, 30, 54, 22],
    [ 3, 35, 11, 43,  1, 33,  9, 41],
    [51, 19, 59, 27, 49, 17, 57, 25],
    [15, 47,  7, 39, 13, 45,  5, 37],
    [63, 31, 55, 23, 61, 29, 53, 21],
], dtype=np.float32)


def hex2rgb(h):
    h = h.strip().lstrip("#")
    if len(h) == 3:
        h = "".join(c * 2 for c in h)
    return np.array([int(h[i:i + 2], 16) for i in (0, 2, 4)], dtype=np.float32)


def luma(c):
    return float(0.299 * c[0] + 0.587 * c[1] + 0.114 * c[2])


# sRGB <-> linear-light (gamma 2.2 approx). Mixing in linear light keeps the
# transition between two accents from passing through muddy mid-grey/brown.
def to_lin(c):
    return (np.clip(c, 0, 255) / 255.0) ** 2.2


def to_srgb(c):
    return np.clip(c, 0.0, 1.0) ** (1.0 / 2.2) * 255.0


def hsv2rgb(hh, ss, vv):
    """Vectorized HSV→RGB. hh/ss/vv are float arrays in 0..1 (same shape);
    returns an array of that shape + a trailing length-3 axis, in 0..255. Used by
    the saturated styles (tiedye/ribbon) where the look is hue-driven, not a
    desaturated nudge off the base like the calm styles."""
    i = np.floor(hh * 6.0).astype(np.int64)
    f = hh * 6.0 - i
    i = i % 6
    p = vv * (1.0 - ss)
    q = vv * (1.0 - f * ss)
    t = vv * (1.0 - (1.0 - f) * ss)
    r = np.choose(i, [vv, q, p, p, t, vv])
    g = np.choose(i, [t, vv, vv, q, p, p])
    b = np.choose(i, [p, p, t, vv, vv, q])
    return np.stack([r, g, b], axis=-1) * 255.0


def working_base(raw_bg):
    """Luminance-aware darken of the raw theme bg into the texture's base color.

    Dark themes darken hard (deep gutter); light themes barely move (paper stays
    paper). k ranges ~0.62 (black) .. ~0.92 (white)."""
    c = hex2rgb(raw_bg)
    L = luma(c) / 255.0
    k = 0.62 + 0.30 * L
    return c * k


# Color-harmony schemes, anchored on the theme background hue. Each is
# (base_hue_offset_deg, [accent_offset_deg, ...]) where 0° == the theme's own
# hue. complement flips the field to the opposite of the terminal; the milder
# schemes shift it less. Offset 0 is kept among the accents as a tie-back to the
# terminal so the wallpaper still references the theme it came from.
HARMONY = {
    "complement": (180, [0, 180]),
    "split":      (180, [0, 150, 210]),
    "triad":      (120, [0, 120, 240]),
    "analogous":  (30,  [0, 30, 60]),
}


def _hsv_hex(h, s, v):
    r, g, b = colorsys.hsv_to_rgb(h % 1.0, max(0.0, min(1.0, s)), v)
    return "#%02x%02x%02x" % (round(r * 255), round(g * 255), round(b * 255))


def harmonize_base(raw_bg, mode, sat_floor=0.30):
    """Rotate the raw theme bg hue by the scheme's base offset, lifting
    saturation to sat_floor so the rotated hue survives the working_base darken
    (a near-grey bg rotated 180° is still near-grey, so the complement wouldn't
    read without this). Value is preserved → dark themes stay dark."""
    if mode not in HARMONY:
        return raw_bg
    H, S, V = colorsys.rgb_to_hsv(*(hex2rgb(raw_bg) / 255.0))
    return _hsv_hex(H + HARMONY[mode][0] / 360.0, max(S, sat_floor), V)


def harmony_accents(raw_bg, mode):
    """Generate vivid accents at the scheme's hue angles (relative to the theme
    bg hue), replacing the theme's own palette. Kept saturated (the calm styles
    desaturate toward the base themselves), mid value so they read on any base."""
    if mode not in HARMONY:
        return None
    H = colorsys.rgb_to_hsv(*(hex2rgb(raw_bg) / 255.0))[0]
    return [_hsv_hex(H + off / 360.0, 0.65, 0.80) for off in HARMONY[mode][1]]


def pick_accents(accents, seed, n=None):
    """Seeded shuffle of the accent list so styles don't always grab the same
    palette slot (the caller hands them in a fixed red,green,blue,magenta order).
    Deterministic per seed → stable for a given theme, varied across themes."""
    if not accents:
        return accents
    rng = np.random.default_rng((seed ^ 0xACCE) & 0xFFFFFFFF)
    out = [accents[i] for i in rng.permutation(len(accents))]
    return out if n is None else out[:n]


def _bayer_tile(w, h):
    ty = (h + 7) // 8
    tx = (w + 7) // 8
    return np.tile(BAYER8 / 64.0, (ty, tx))[:h, :w]


def _finish(img, w, h, seed, dither, grain):
    """Common tail: ordered dither (kills banding) + faint film grain (matte
    surface, not a blur), then quantize to 8-bit."""
    rng = np.random.default_rng(seed ^ 0x9E3779B9)
    if dither > 0:
        img = img + (_bayer_tile(w, h)[..., None] - 0.5) * dither
    if grain > 0:
        img = img + (rng.random((h, w, 1)) - 0.5) * grain
    return Image.fromarray(np.clip(np.round(img), 0, 255).astype(np.uint8))


# ── styles ───────────────────────────────────────────────────────────────────

def render_mesh(w, h, base, accents, seed, opts):
    rng = np.random.default_rng(seed)
    L = luma(base) / 255.0
    # Dark base needs a bigger light/dark swing to read as a gradient at all.
    lift = 55.0 * (1.0 - L) + 14.0
    blend = opts["blend"]
    base_lin = to_lin(base)

    def rim():
        # A point out toward the edges/corners (never the dead center).
        a = rng.random() * 2 * math.pi
        r = 0.55 + 0.45 * rng.random()
        return np.array([0.5 + r * math.cos(a) * 0.6,
                         0.5 + r * math.sin(a) * 0.5], dtype=np.float32)

    cols = [base_lin]
    pts = [np.array([0.5, 0.5], dtype=np.float32)]   # base anchor = calm center
    cols.append(to_lin(np.clip(base + lift, 0, 255)));       pts.append(rim())
    cols.append(to_lin(np.clip(base - lift * 0.7, 0, 255))); pts.append(rim())
    for a in pick_accents(accents, seed, 3):         # at most 3, desaturated
        tint = np.clip(base * (1.0 - blend) + hex2rgb(a) * blend, 0, 255)
        cols.append(to_lin(tint));                           pts.append(rim())
    cols = np.array(cols, dtype=np.float32)
    pts = np.array(pts, dtype=np.float32)

    xs = np.linspace(0.0, 1.0, w, dtype=np.float32)
    ys = np.linspace(0.0, 1.0, h, dtype=np.float32)
    asp = w / h
    gx, gy = np.meshgrid(xs * asp, ys)

    acc = np.zeros((h, w, 3), dtype=np.float32)
    wsum = np.zeros((h, w), dtype=np.float32)
    power = opts["power"]
    for (px, py), col in zip(pts, cols):
        d2 = (gx - px * asp) ** 2 + (gy - py) ** 2 + 1e-3
        wt = d2 ** (-power / 2.0)
        wsum += wt
        acc += wt[..., None] * col[None, None, :]
    img = acc / wsum[..., None]

    # Center-calm vignette: pull toward the base color in the middle third, where
    # windows sit, so the visual interest stays at the edges.
    vx = (gx / asp - 0.5)
    vy = gy - 0.5
    rad = np.sqrt(vx * vx + vy * vy) / 0.5
    calm = (np.clip(1.0 - rad, 0.0, 1.0) ** 2) * 0.32
    img = img * (1.0 - calm[..., None]) + base_lin[None, None, :] * calm[..., None]

    return _finish(to_srgb(img), w, h, seed, opts["dither"], opts["grain"])


def render_flat(w, h, base, accents, seed, opts):
    rng = np.random.default_rng(seed)
    L = luma(base) / 255.0
    lift = 26.0 * (1.0 - L) + 8.0
    # Random-but-seeded diagonal direction; gradient runs corner-to-corner.
    a = rng.random() * 2 * math.pi
    dx, dy = math.cos(a), math.sin(a)
    xs = np.linspace(-0.5, 0.5, w, dtype=np.float32)
    ys = np.linspace(-0.5, 0.5, h, dtype=np.float32)
    gx, gy = np.meshgrid(xs, ys)
    t = (gx * dx + gy * dy)
    t = (t - t.min()) / (np.ptp(t) + 1e-9)            # 0..1 along the diagonal
    lo = to_lin(np.clip(base - lift * 0.4, 0, 255))
    hi = to_lin(np.clip(base + lift * 0.6, 0, 255))
    img = lo[None, None, :] * (1 - t[..., None]) + hi[None, None, :] * t[..., None]

    # A whisper of accent glow in one corner.
    sel = pick_accents(accents, seed, 1)
    if sel:
        ac = to_lin(np.clip(base * 0.85 + hex2rgb(sel[0]) * 0.15, 0, 255))
        cx, cy = rng.choice([0.08, 0.92]), rng.choice([0.1, 0.9])
        asp = w / h
        gxx, gyy = np.meshgrid(np.linspace(0, 1, w, dtype=np.float32) * asp,
                               np.linspace(0, 1, h, dtype=np.float32))
        d = np.sqrt((gxx - cx * asp) ** 2 + (gyy - cy) ** 2)
        glow = np.clip(1.0 - d / 0.6, 0.0, 1.0) ** 2 * 0.5
        img = img * (1 - glow[..., None]) + ac[None, None, :] * glow[..., None]

    return _finish(to_srgb(img), w, h, seed, opts["dither"], opts["grain"])


def _blur5(a):
    """Cheap dependency-free separable blur (5-tap [1,4,6,4,1]) — used to thicken
    1px flow-field streaks into legible strokes without scipy/PIL float blur."""
    k = np.array([1, 4, 6, 4, 1], dtype=np.float32)
    k /= k.sum()
    pad = np.pad(a, ((0, 0), (2, 2)), mode="edge")
    out = sum(k[i] * pad[:, i:i + a.shape[1]] for i in range(5))
    pad = np.pad(out, ((2, 2), (0, 0)), mode="edge")
    return sum(k[i] * pad[i:i + a.shape[0], :] for i in range(5))


def _cmap_sample(pal, t):
    """Sample a palette (m x3 sRGB) as a smooth colormap at t in 0..1, mixing
    neighbors in linear light. Used to give each flow particle a position-based
    hue so adjacent streams share color (coherent bands, no muddy averaging)."""
    m = len(pal)
    if m == 1:
        return np.repeat(pal, len(t), axis=0)
    pos = np.clip(t, 0, 1) * (m - 1)
    i0 = np.clip(np.floor(pos).astype(np.int64), 0, m - 2)
    fr = (pos - i0)[..., None]
    lin = to_lin(pal)
    return to_srgb(lin[i0] * (1.0 - fr) + lin[i0 + 1] * fr)


def render_flow(w, h, base, accents, seed, opts):
    """Flow field: thousands of particles streamed along a noise vector field,
    accumulated into an ink buffer and composited over the base. Particles are
    hued by a smooth field of their start position, accents kept saturated →
    coherent multicolor streams across the canvas."""
    rng = np.random.default_rng(seed)
    n = 4600                               # particles
    steps = 320                            # integration steps per particle
    step_px = max(1.5, w / 900.0)

    # Analytic noise field: theta(x,y) = a weighted sum of low-frequency sines,
    # so we can evaluate the flow direction at any particle without a grid lookup.
    K = 5
    A = rng.normal(0, 2.2, K)
    Bx = rng.normal(0, 2.4, K)
    By = rng.normal(0, 2.4, K)
    PH = rng.random(K) * 6.28318
    swirl = rng.uniform(1.5, 2.6)

    def theta(nx, ny):
        f = np.zeros_like(nx)
        for k in range(K):
            f += A[k] * np.sin(Bx[k] * nx * math.pi + By[k] * ny * math.pi + PH[k])
        return f * swirl

    px = rng.random(n) * w
    py = rng.random(n) * h
    sel = pick_accents(accents, seed)
    if not sel:
        sel = ["#%02x%02x%02x" % tuple(np.clip(base + 50, 0, 255).astype(int))]

    # Hue by a smooth field of the START position → coherent color bands.
    pal = np.array([hex2rgb(a) for a in sel], dtype=np.float32) * 0.92 + base * 0.08
    nx0, ny0 = px / w, py / h
    cp = rng.random(2) * 6.28318
    tg = (np.sin(1.7 * nx0 * math.pi + 1.1 * ny0 * math.pi + cp[0])
          + 0.6 * np.sin(2.3 * ny0 * math.pi - 0.9 * nx0 * math.pi + cp[1]))
    tg = (tg - tg.min()) / (np.ptp(tg) + 1e-9)
    pcol = _cmap_sample(pal, tg)
    alpha = opts["flow_alpha"] * 1.25
    comp_max = 0.82

    ink = np.zeros((h, w), dtype=np.float32)
    colacc = np.zeros((h, w, 3), dtype=np.float32)
    a_per = (alpha / (steps ** 0.5)) * 6.0
    for _ in range(steps):
        th = theta(px / w, py / h)
        px = px + np.cos(th) * step_px
        py = py + np.sin(th) * step_px
        xi = np.floor(px).astype(np.int64)
        yi = np.floor(py).astype(np.int64)
        m = (xi >= 0) & (xi < w) & (yi >= 0) & (yi < h)
        if not m.any():
            break
        xim, yim, cm = xi[m], yi[m], pcol[m]
        np.add.at(ink, (yim, xim), a_per)
        for c in range(3):
            np.add.at(colacc, (yim, xim, c), a_per * cm[:, c])

    ink = _blur5(ink)
    for c in range(3):
        colacc[..., c] = _blur5(colacc[..., c])
    streak = colacc / np.maximum(ink, 1e-6)[..., None]

    base_lin = to_lin(np.ones((h, w, 3), dtype=np.float32) * base[None, None, :])
    comp = np.clip(np.clip(ink, 0, 1), 0, comp_max)[..., None]
    out = to_srgb(base_lin * (1.0 - comp) + to_lin(streak) * comp)
    return _finish(out, w, h, seed, 2.0, opts["grain"])


def render_tiedye(w, h, base, accents, seed, opts):
    """Psychedelic spiral tie-dye: a full-spectrum rainbow folded around a center
    (angle → pinwheel, radius → rings; together a spiral), warped by a low-freq
    crinkle field so the dye reads as bled into fabric rather than mathematically
    clean. Unapologetically vivid — unlike the calm styles it does NOT hug the base
    value — but a center vignette darkens toward the theme bg so windows stay
    legible. accents are ignored on purpose: tie-dye is the rainbow."""
    rng = np.random.default_rng(seed)
    L = luma(base) / 255.0
    asp = w / h
    xs = np.linspace(0.0, 1.0, w, dtype=np.float32)
    ys = np.linspace(0.0, 1.0, h, dtype=np.float32)
    gx, gy = np.meshgrid(xs * asp, ys)

    # Dye center, jittered off the middle so the spiral isn't dead-centered.
    cx = (0.5 + (rng.random() - 0.5) * 0.25) * asp
    cy = 0.5 + (rng.random() - 0.5) * 0.25
    dx, dy = gx - cx, gy - cy
    r = np.sqrt(dx * dx + dy * dy)
    ang = np.arctan2(dy, dx)

    # Crinkle: a few low-frequency sines warp the hue field → organic bleed.
    warp = np.zeros((h, w), dtype=np.float32)
    for _ in range(3):
        a1, a2 = rng.normal(0, 2.0, 2)
        ph = rng.random() * 6.28318
        warp += np.sin(a1 * gx * math.pi + a2 * gy * math.pi + ph)
    warp *= 0.11

    folds = int(rng.integers(5, 9))         # pinwheel sections
    twist = rng.uniform(2.8, 4.6)           # how tight the spiral winds
    hue = (ang * folds / (2 * math.pi) + r * twist + warp + rng.random()) % 1.0
    sat = np.clip(0.80 + 0.18 * np.sin(r * twist * 1.7 + warp * 3.0), 0.5, 1.0)
    val = 0.86 + 0.12 * np.sin(ang * folds + r * twist + 1.3)

    rgb = hsv2rgb(hue.astype(np.float32), sat.astype(np.float32),
                  val.astype(np.float32))

    # Center-calm vignette → toward a darkened theme bg, so the saturated rim
    # frames the windows that sit in the middle.
    base_d = base * (0.45 + 0.30 * L)
    vx, vy = (gx / asp - 0.5), (gy - 0.5)
    rad = np.sqrt(vx * vx + vy * vy) / 0.5
    calm = (np.clip(1.0 - rad, 0.0, 1.0) ** 2) * 0.40
    img = to_srgb(to_lin(rgb) * (1.0 - calm[..., None])
                  + to_lin(base_d)[None, None, :] * calm[..., None])
    return _finish(img, w, h, seed, opts["dither"], opts["grain"])


def render_ribbon(w, h, base, accents, seed, opts):
    """2000s flowy 3D ribbons, lit as twisting glossy tubes. Each ribbon has a
    semicircular cross-section shaded with Lambert diffuse + Blinn-Phong specular
    (a tight highlight, not a soft blob), a TWIST that migrates the lit side across
    the width and rolls a darker/desaturated BACK face into view, a soft drop
    shadow onto the layers behind, and depth cueing (far ribbons thinner + dimmer),
    so they read as solid 3D bands rather than flat gaussians. Painted far→near for
    correct occlusion; hued across the spectrum so overlaps blend like a Vista/WMP
    aurora; center-calmed so windows stay legible."""
    rng = np.random.default_rng(seed)
    L = luma(base) / 255.0
    xs = np.linspace(0.0, 1.0, w, dtype=np.float32)
    ys = np.linspace(0.0, 1.0, h, dtype=np.float32)
    gx, gy = np.meshgrid(xs, ys)

    out_lin = to_lin(np.ones((h, w, 3), dtype=np.float32) * base[None, None, :])
    nrib = int(rng.integers(5, 8))
    hue0 = rng.random()
    # Center-calm: fade ribbon opacity in the middle third where windows live.
    cdist = np.abs(gy - 0.5) * 2.0
    center_fade = np.clip(0.35 + 0.65 * cdist, 0.0, 1.0)

    # Light + half-vector for Blinn-Phong; view is straight on (+z). Light from
    # the upper-left so the highlight sits where the eye expects a top-lit tube.
    Ld = np.array([-0.45, -0.55, 0.70], dtype=np.float32); Ld /= np.linalg.norm(Ld)
    Hd = Ld + np.array([0, 0, 1], dtype=np.float32);       Hd /= np.linalg.norm(Hd)
    shy = max(2, int(h * 0.012))                            # drop-shadow offset (px)

    # Paint far→near so nearer ribbons occlude correctly and depth reads right.
    for k, z in enumerate(sorted(rng.uniform(0.0, 1.0, nrib))):
        hue = (hue0 + k / nrib + rng.uniform(-0.04, 0.04)) % 1.0
        amp = rng.uniform(0.08, 0.17)
        freq = rng.uniform(1.0, 2.2)
        freq2 = rng.uniform(2.6, 4.0)
        ph = rng.random() * 6.28318
        y0 = rng.uniform(0.14, 0.86)
        near = 0.55 + 0.45 * z                              # 1=near, ~0.55=far
        thick = rng.uniform(0.05, 0.10) * near             # far ribbons thinner
        center = (y0 + amp * np.sin(freq * gx * 2 * math.pi + ph)
                  + 0.4 * amp * np.sin(freq2 * gx * 2 * math.pi + ph * 1.7))
        u = (gy - center) / thick                          # cross-ribbon coord

        # Twist along the length: shifts the cross-section so the highlight slides
        # across the width and the far edge rolls to a back face.
        twist = np.sin(rng.uniform(2.0, 3.5) * gx * 2 * math.pi + rng.random() * 6.283)
        uu = u + 0.55 * twist

        # Semicircular tube normal N=(0, ny, nz): center faces the viewer, edges
        # roll away. Diffuse + a tight specular give the round, glossy read.
        body = np.clip(1.0 - uu * uu, 0.0, 1.0)
        nz = np.sqrt(body + 1e-6)
        ny = np.clip(uu, -1.0, 1.0)
        diffuse = 0.40 + 0.70 * np.clip(ny * Ld[1] + nz * Ld[2], 0.0, 1.0)
        spec = np.power(np.clip(ny * Hd[1] + nz * Hd[2], 0.0, 1.0), 42.0)
        front = np.abs(uu) <= 1.0                           # back face = rolled past
        sat = np.where(front, 0.72, 0.45).astype(np.float32)
        val = np.where(front, 0.95 - 0.10 * L, 0.50 - 0.08 * L).astype(np.float32)
        col = hsv2rgb(np.full_like(gx, hue, dtype=np.float32), sat, val)
        shaded = col * diffuse[..., None] + 255.0 * spec[..., None]

        # Coverage: a solid body with a soft AA silhouette (defined edge → 3D),
        # plus rim darkening just inside the edge to round the tube off.
        cov = np.clip((1.0 - np.abs(u)) / 0.14, 0.0, 1.0)
        rim = 1.0 - 0.40 * np.clip((np.abs(u) - 0.55) / 0.45, 0.0, 1.0)
        ribcol = to_lin(np.clip(shaded * rim[..., None], 0, 255))

        # Soft drop shadow onto whatever's already painted (offset down-right).
        sh = np.zeros_like(cov)
        sh[shy:, shy:] = cov[:-shy, :-shy]
        out_lin *= (1.0 - ((sh * center_fade)[..., None] * 0.28))

        a = (cov * center_fade)[..., None] * (0.88 * near)
        out_lin = out_lin * (1.0 - a) + ribcol * a

    return _finish(to_srgb(out_lin), w, h, seed, 2.0, opts["grain"])


STYLES = {
    "mesh": render_mesh,
    "tiedye": render_tiedye,
    "ribbon": render_ribbon,
    "flat": render_flat,
    "flow": render_flow,
}


def main():
    ap = argparse.ArgumentParser(description="procedural theme wallpaper")
    ap.add_argument("--out", required=True)
    ap.add_argument("--size", default="3840x2160", help="WxH (4K default)")
    ap.add_argument("--base", required=True,
                    help="#rrggbb RAW theme background (darkened internally)")
    ap.add_argument("--accents", default="", help="comma-separated #rrggbb")
    ap.add_argument("--seed", type=int, default=0)
    ap.add_argument("--style", default="mesh", choices=sorted(STYLES),
                    help="which procedural look to render")
    ap.add_argument("--blend", type=float, default=0.30,
                    help="mesh: 0..1 how far accent points move from base")
    ap.add_argument("--dither", type=float, default=2.0,
                    help="ordered-dither amplitude in 0..255 levels (0 = off)")
    ap.add_argument("--grain", type=float, default=3.0,
                    help="film-grain amplitude in 0..255 levels (0 = off)")
    ap.add_argument("--power", type=float, default=1.6,
                    help="mesh: inverse-distance falloff (higher = sharper blobs)")
    ap.add_argument("--flow-alpha", type=float, default=0.5,
                    help="flow: streak opacity (higher = denser/brighter streams)")
    ap.add_argument("--harmony", default="mono",
                    choices=["mono"] + sorted(HARMONY),
                    help="rotate the field around the color wheel relative to the "
                         "theme hue (mono = in-hue, the default)")
    a = ap.parse_args()

    w, h = (int(x) for x in a.size.lower().split("x"))
    accents = [c for c in a.accents.split(",") if c.strip()]
    # Harmony rotates the field's hue off the theme; mono leaves it in-hue. Done
    # on the RAW bg, before the luminance-aware darken below.
    raw = a.base
    if a.harmony != "mono":
        raw = harmonize_base(a.base, a.harmony)
        accents = harmony_accents(a.base, a.harmony)
    base = working_base(raw)
    opts = {"blend": a.blend, "dither": a.dither, "grain": a.grain,
            "power": a.power, "flow_alpha": a.flow_alpha}
    img = STYLES[a.style](w, h, base, accents, a.seed, opts)
    img.save(a.out)


if __name__ == "__main__":
    main()
